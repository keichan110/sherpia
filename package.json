{
  "name": "notion-knowledge-feeder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c && cp appsscript.json dist/",
    "build:watch": "rollup -c --watch",
    "push": "pnpm build && pnpm exec clasp push",
    "push:force": "pnpm build && pnpm exec clasp push --force",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@google/clasp": "^3.3.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/google-apps-script": "^1.0.83",
    "rollup": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.4.0"
  },
  "packageManager": "pnpm@11.4.0"
}
